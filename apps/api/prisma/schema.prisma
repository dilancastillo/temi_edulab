generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TEACHER
  STUDENT
  INSTITUTION_ADMIN
  ADMIN
}

enum AuthProvider {
  PASSWORD
  GOOGLE
  MICROSOFT
  MISSION_CODE
  DEVICE
}

enum StudentProgress {
  IN_PROGRESS
  NEEDS_REVIEW
  GRADED
}

enum MissionCategory {
  FUNDAMENTALS
  LOGIC
  CONTROL
  ROBOTICS
}

enum MissionAgeBand {
  AGE_7_10
  AGE_11_14
  AGE_15_18
}

enum MissionStatus {
  PUBLISHED
  DRAFT
}

enum CoverTone {
  BLUE
  GREEN
  YELLOW
  RED
  INDIGO
  SLATE
}

enum AssignmentStatus {
  ACTIVE
  ARCHIVED
}

enum StudentWorkStatus {
  DRAFT
  SUBMITTED
}

enum ClassSessionStatus {
  PENDING_APPROVAL
  READY
  RUNNING
  PAUSED
  ERROR
  SAFE_MODE
  COMPLETED
}

enum PairingStatus {
  PENDING
  CONFIRMED
  CONSUMED
  EXPIRED
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum CampusStatus {
  ACTIVE
  INACTIVE
}

enum SpaceKind {
  CLASSROOM
  LIBRARY
  LAB
  AUDITORIUM
  MAKERSPACE
  OFFICE
  OTHER
}

enum LicenseStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum DataPolicyKind {
  PRIVACY
  DATA_PROCESSING
  MINORS_NOTICE
  ROBOT_USE
  MARKETING
}

enum DataPolicyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TemplateKind {
  REPORT
  CERTIFICATE
  COMMUNICATION
  RUBRIC
  CONSENT
  WORKSHOP_GUIDE
}

enum TemplateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ARCHIVED
}

enum AuditAction {
  CREATED
  UPDATED
  PUBLISHED
  CONFIRMED
  SUSPENDED
}

model Institution {
  id            String          @id
  name          String
  slug          String          @unique
  legalName     String?
  daneCode      String?
  department    String?
  city          String?
  country       String          @default("Colombia")
  defaultLocale String          @default("es-CO")
  enabledLevels Json?
  dataPolicyMode String         @default("TEMPLATE")
  marketingConsentEnabled Boolean @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  campuses      Campus[]
  floors        BuildingFloor[]
  spaces        LearningSpace[]
  courses       Course[]
  users         User[]
  assignments   Assignment[]
  studentWorks  StudentWork[]
  robots        Robot[]
  classSessions ClassSession[]
  pairingRequests PairingRequest[]
  licenses      InstitutionLicense[]
  branding      InstitutionBranding?
  policies      InstitutionPolicy[]
  policyAcceptances PolicyAcceptance[]
  templates     InstitutionTemplate[]
  reportSnapshots InstitutionReportSnapshot[]
  maintenanceRecords RobotMaintenanceRecord[]
  auditLogs     AuditLog[]
}

model Course {
  id            String          @id
  institutionId String
  campusId      String?
  name          String
  level         String
  academicLevel String?
  gradeLabel    String?
  groupLabel    String?
  academicYear  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  institution   Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  campus        Campus?         @relation(fields: [campusId], references: [id], onDelete: SetNull)
  students      User[]          @relation("CourseStudents")
  assignments   Assignment[]
  robots        Robot[]
  classSessions ClassSession[]

  @@unique([institutionId, name])
}

model User {
  id               String           @id
  institutionId    String?
  courseId         String?
  role             UserRole
  accountStatus    AccountStatus    @default(ACTIVE)
  authProvider     AuthProvider     @default(PASSWORD)
  fullName         String
  email            String           @unique
  passwordHash     String?
  biography        String?
  avatarUrl        String?
  permissions      Json?
  locale           String           @default("es-CO")
  progress         StudentProgress?
  currentMissionId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  institution      Institution?     @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  course           Course?          @relation("CourseStudents", fields: [courseId], references: [id], onDelete: SetNull)
  teacherAssignments Assignment[]   @relation("AssignmentsByTeacher")
  studentWorks     StudentWork[]    @relation("StudentWorksByStudent")
  webSessions      WebSession[]
  taughtSessions   ClassSession[]   @relation("ClassSessionsByTeacher")
  pairingApprovals PairingRequest[] @relation("PairingApprovedBy")
  policyAcceptances PolicyAcceptance[]
  approvedTemplates InstitutionTemplate[] @relation("TemplateApprovedBy")
  auditLogs        AuditLog[]
}

model WebSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Mission {
  id              String          @id
  title           String
  summary         String
  category        MissionCategory
  ageBand         MissionAgeBand
  durationMinutes Int
  outcomes        Json
  status          MissionStatus
  coverTone       CoverTone
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assignments     Assignment[]
  studentWorks    StudentWork[]
}

model Assignment {
  id             String           @id
  institutionId  String
  courseId       String
  missionId      String
  missionCode    String           @unique
  instructions   String?
  status         AssignmentStatus
  assignedAt     DateTime
  assignedById   String
  completedCount Int              @default(0)
  reviewCount    Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  institution    Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  mission        Mission          @relation(fields: [missionId], references: [id], onDelete: Cascade)
  assignedBy     User             @relation("AssignmentsByTeacher", fields: [assignedById], references: [id], onDelete: Restrict)
  studentWorks   StudentWork[]
  classSessions  ClassSession[]

  @@index([institutionId, status])
  @@index([courseId, status])
}

model StudentWork {
  id            String            @id
  institutionId String
  studentId     String
  assignmentId  String
  missionId     String
  workspaceState Json?
  stepIndex     Int
  status        StudentWorkStatus
  updatedAt     DateTime
  submittedAt   DateTime?
  createdAt     DateTime          @default(now())
  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student       User              @relation("StudentWorksByStudent", fields: [studentId], references: [id], onDelete: Cascade)
  assignment    Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  mission       Mission           @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
}

model Robot {
  id              String          @id
  institutionId   String
  courseId        String?
  campusId        String?
  floorId         String?
  spaceId         String?
  displayName     String
  slug            String          @unique
  serialNumber    String?
  modelName       String?
  firmwareVersion String?
  sdkVersion      String?
  maintenanceStatus String?
  classroomName   String?
  pairCode        String?         @unique
  pairCodeExpiresAt DateTime?
  deviceTokenHash String?         @unique
  tokenExpiresAt  DateTime?
  connectionState String          @default("CHECKING")
  batteryPercent  Int?
  statusLabel     String?
  lastSeenAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  institution     Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  course          Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  campus          Campus?         @relation(fields: [campusId], references: [id], onDelete: SetNull)
  floor           BuildingFloor?  @relation(fields: [floorId], references: [id], onDelete: SetNull)
  space           LearningSpace?  @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  locations       RobotLocation[]
  classSessions   ClassSession[]
  robotEvents     RobotEvent[]
  pairingRequests PairingRequest[]
  maintenanceRecords RobotMaintenanceRecord[]

  @@index([institutionId])
  @@index([campusId])
}

model RobotLocation {
  id              String   @id @default(cuid())
  robotId         String
  name            String
  normalizedName  String
  available       Boolean
  detail          String?
  lastValidatedAt DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  robot           Robot    @relation(fields: [robotId], references: [id], onDelete: Cascade)

  @@unique([robotId, normalizedName])
  @@index([robotId, available])
}

model ClassSession {
  id               String             @id
  institutionId    String
  robotId          String
  courseId         String
  assignmentId     String
  teacherId        String
  classroomName    String
  missionTitle     String
  activeStudentName String?
  status           ClassSessionStatus
  missionRuntime   Json
  currentStepLabel String?
  progressPercent  Int                @default(0)
  approvedAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  institution      Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  robot            Robot              @relation(fields: [robotId], references: [id], onDelete: Cascade)
  course           Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignment       Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  teacher          User               @relation("ClassSessionsByTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  robotEvents      RobotEvent[]

  @@index([robotId, status])
  @@index([institutionId, status])
}

model RobotEvent {
  id             String       @id @default(cuid())
  robotId        String
  classSessionId String?
  idempotencyKey String       @unique
  eventType      String
  payload        Json
  createdAt      DateTime     @default(now())
  robot          Robot        @relation(fields: [robotId], references: [id], onDelete: Cascade)
  classSession   ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)

  @@index([robotId, createdAt])
}

model PairingRequest {
  id                 String        @id @default(cuid())
  robotId            String?
  institutionId      String?
  confirmedById      String?
  code               String        @unique
  proposedName       String
  classroomName      String?
  sessionUri         String?
  status             PairingStatus @default(PENDING)
  pendingDeviceToken String?
  expiresAt          DateTime
  confirmedAt        DateTime?
  consumedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  robot              Robot?        @relation(fields: [robotId], references: [id], onDelete: SetNull)
  institution        Institution?  @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  confirmedBy        User?         @relation("PairingApprovedBy", fields: [confirmedById], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
}

model Campus {
  id            String       @id @default(cuid())
  institutionId String
  name          String
  city          String
  address       String?
  phone         String?
  status        CampusStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  floors        BuildingFloor[]
  spaces        LearningSpace[]
  courses       Course[]
  robots        Robot[]

  @@index([institutionId, status])
}

model BuildingFloor {
  id            String       @id @default(cuid())
  institutionId String
  campusId      String
  name          String
  levelNumber   Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  campus        Campus       @relation(fields: [campusId], references: [id], onDelete: Cascade)
  spaces        LearningSpace[]
  robots        Robot[]

  @@index([institutionId])
  @@unique([campusId, levelNumber])
}

model LearningSpace {
  id                 String       @id @default(cuid())
  institutionId      String
  campusId           String
  floorId            String?
  name               String
  kind               SpaceKind
  capacity           Int?
  safetyNotes        String?
  accessibilityNotes String?
  isRobotReady       Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  institution        Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  campus             Campus       @relation(fields: [campusId], references: [id], onDelete: Cascade)
  floor              BuildingFloor? @relation(fields: [floorId], references: [id], onDelete: SetNull)
  robots             Robot[]

  @@index([institutionId, kind])
  @@index([campusId])
}

model InstitutionLicense {
  id            String        @id @default(cuid())
  institutionId String
  name          String
  status        LicenseStatus @default(TRIAL)
  startsAt      DateTime
  endsAt        DateTime
  maxRobots     Int
  maxTeachers   Int
  maxStudents   Int
  maxMissions   Int
  trialMode     Boolean       @default(true)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, status])
}

model InstitutionBranding {
  id                String      @id @default(cuid())
  institutionId     String      @unique
  logoUrl           String?
  sealUrl           String?
  primaryColor      String      @default("#2856a6")
  accentColor       String      @default("#1f9d55")
  neutralColor      String      @default("#f4f7fb")
  marketingHeadline String?
  welcomeMessage    String?
  reportFooter      String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  institution       Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionPolicy {
  id              String           @id @default(cuid())
  institutionId   String
  kind            DataPolicyKind
  title           String
  version         String
  status          DataPolicyStatus @default(DRAFT)
  content         String
  sourceReference String?
  effectiveAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  institution     Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  acceptances     PolicyAcceptance[]

  @@unique([institutionId, kind, version])
  @@index([institutionId, status])
}

model PolicyAcceptance {
  id            String            @id @default(cuid())
  institutionId String
  userId        String
  policyId      String
  acceptedAt    DateTime          @default(now())
  ipAddress     String?
  userAgent     String?
  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy        InstitutionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([userId, policyId])
  @@index([institutionId, acceptedAt])
}

model InstitutionTemplate {
  id               String         @id @default(cuid())
  institutionId    String
  kind             TemplateKind
  name             String
  status           TemplateStatus @default(DRAFT)
  content          String
  variables        Json
  requiresApproval Boolean        @default(true)
  approvedAt       DateTime?
  approvedById     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  institution      Institution    @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  approvedBy       User?          @relation("TemplateApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([institutionId, kind, status])
}

model InstitutionReportSnapshot {
  id            String      @id @default(cuid())
  institutionId String
  kind          String
  title         String
  rangeStart    DateTime
  rangeEnd      DateTime
  metrics       Json
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, kind, createdAt])
}

model RobotMaintenanceRecord {
  id            String   @id @default(cuid())
  institutionId String
  robotId       String
  kind          String
  status        String
  notes         String?
  dueAt         DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  robot         Robot    @relation(fields: [robotId], references: [id], onDelete: Cascade)

  @@index([institutionId, status])
  @@index([robotId, createdAt])
}

model AuditLog {
  id            String      @id @default(cuid())
  institutionId String
  actorId       String?
  action        AuditAction
  resourceType  String
  resourceId    String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  actor         User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([institutionId, createdAt])
}
