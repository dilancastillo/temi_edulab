{
  "name": "esbot-edulab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "dev:web": "next dev --hostname 0.0.0.0",
    "dev:api": "npm run dev --workspace apps/api",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "prisma:generate": "npm run prisma:generate --workspace apps/api",
    "prisma:migrate": "npm run prisma:migrate --workspace apps/api",
    "prisma:seed": "npm run prisma:seed --workspace apps/api",
    "build": "next build",
    "build:api": "npm run build --workspace apps/api",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "npm run typecheck --workspace apps/api"
  },
  "dependencies": {
    "blockly": "12.5.1",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "jsdom": "29.0.2",
    "typescript": "6.0.2",
    "vitest": "3.2.4"
  }
}
